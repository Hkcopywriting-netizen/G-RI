# Q2 2024 # ⚠️ CHANGED
cards_Q22024_update <- cards_Q22024 %>% # ⚠️ CHANGED
  select(party_id, acct_id, year, company, subcode) %>%
  left_join(tbl(sc, "bc3.trades") %>%
              filter(data_date == "2025-06-30"), # ⚠️ CHANGED
            by = c("party_id", "acct_id")) %>%
  compute("cards_Q22024_update") # ⚠️ CHANGED

perf_exits <- cards_Q22024_update %>% # ⚠️ CHANGED
  naPerf(usehist = FALSE) %>%
  ungroup() %>%
  compute("perf_exits")

data_perf_join <- left_join(
  cards_Q22024_update, # ⚠️ CHANGED
  perf_exits,
  by = c("party_id", "acct_id")) %>%
  compute("data_perf_join")

chgoff <- cards_Q22024_update %>% # ⚠️ CHANGED
  naCO_tr() %>%
  ungroup() %>%
  compute("chgoff")

Q2_2024_updated <- left_join(data_perf_join, # ⚠️ CHANGED
                              chgoff,
                              by = c("party_id", "acct_id")) %>%
  compute("Q2_2024_updated") # ⚠️ CHANGED

dbGetQuery(sc, "create table bu_fs.hpusarl_Q2_2024_12m select * from Q2_2024_updated") # ⚠️ CHANGED

rm(cards_Q22024, cards_Q22024_update, Q2_2024_updated, # ⚠️ CHANGED
   chgoff, data_perf_join, perf_exits)
gc()

