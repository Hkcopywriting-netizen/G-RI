# Function for calculating descriptive statistics for numeric type columns
def numeric_descsumm(x):
    return pd.Series({
        'Mean'      : round(x.mean(), 1),
        'SD'        : round(x.std(), 1),
        'Median'    : int(round(x.median())),
        'Min'       : int(round(x.min())),
        'Max'       : int(round(x.max())),
        'Distinct'  : int(x.nunique()),
        '% Special' : (x < 0).mean()
    })

# Define the predictor set
exclude_cols = ['perf', 'wgt', 'score1', 'score2', 'score3', 'res', 'ind']
valid_preds  = [c for c in data.columns if c not in exclude_cols]
numeric_cols = data[valid_preds].select_dtypes(include='number').columns.tolist()

desc_stats = (
    data[numeric_cols]
    .apply(numeric_descsumm)
    .T
    .reset_index()
    .rename(columns={'index': 'Attribute'})
)

desc_stats.style \
    .format({'% Special': '{:.1%}'}) \
    .set_caption('Descriptive statistics - numeric data') \
    .hide(axis='index')






