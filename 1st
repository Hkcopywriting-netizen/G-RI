# Consolidate drop list
drop_list = pd.concat([
    pd.DataFrame({'Attribute': blacklist,
                  'Reason': 'Blacklist'}),
    pd.DataFrame({'Attribute': zero_variance,
                  'Reason': 'Zero Variance'}),
    pd.DataFrame({'Attribute': [v for v in predictors
                                if v not in zero_variance
                                and v not in base_features['Feature'].tolist()],
                  'Reason': 'Failed XGB'}),
    pd.DataFrame({'Attribute': [name for name, b in bins.items()
                                if 'SUCCESS' not in str(b.reject_code)],
                  'Reason': 'Failed Binning'})
], ignore_index=True)

drop_list.style \
    .set_caption('Variables dropped in reduction') \
    .hide(axis='index')






# Final model variables after binning
model_vars = (
