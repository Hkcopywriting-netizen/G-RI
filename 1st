# Convert dates to datetime
data['open_dte'] = pd.to_datetime(data['open_dte'])
data['customerInput_appDt'] = pd.to_datetime(data['customerInput_appDt'])

# Filter proximity window - 1 month prior to 3 months after application date
data = data[
    (data['customerInput_appDt'] - DateOffset(months=1) <= data['open_dte']) &
    (data['open_dte'] <= data['customerInput_appDt'] + DateOffset(months=3))
]

