# Read Q3 2025
cards_Q32025_Company <- read_csv("/shared/nas/shape/bu_fs/persist/Custom/Proactive-Card_Banking/DQCO/Refresh Requests/June 2026 Refresh/Data/Q3_bad_COrates_2025.csv")

# Read Q3 2024 for comparison
cards_Q32024_Company <- read_csv("/shared/nas/shape/bu_fs/persist/Custom/Proactive-Card_Banking/DQCO/Refresh Requests/June 2026 Refresh/Data/Q3_bad_COrates_2024_12m.csv") %>%
  select(company, bad60in6, bad90in6, COin6)

# Side by Side Bad Rates
cards_sbs <- cards_Q32024_Company %>%
  inner_join(
    cards_Q32025_Company,
    by = "company",
    suffix = c("_2024", "_2025")
  ) %>%
  filter(company %in% c(
    "CAPITAL ONE", "SYNCHRONY", "CHASE", "CITIBANK", "CREDIT ONE BANK", "BANK OF AMERICA",
    "DISCOVER", "AMERICAN EXPRESS", "GOLDMAN SACHS", "BARCLAYS", "WELLS FARGO", "ALLIANCE DATA",
    "GENESIS FINANCIAL SOLUTIONS", "US BANK", "FIRST PREMIER", "MISSION LANE", "FIRST NATIONAL BANK OF OMAHA (FNBO)",
    "ATLANTICUS HOLDINGS", "NAVY FEDERAL CREDIT UNION", "CONTINENTAL FINANCE COMPANY", "MERRICK BANK", "PNC",
    "FIRST BANK & TRUST (SD)", "FIRST NATIONAL BANK/FIRST SAVINGS BANK (SD)", "USAA", "TRUIST FINANCIAL CORP (FKA BB&T/SUNTRUST)",
    "CITIZENS BANK", "BMO FINANCIAL GROUP", "TD BANK (NORDSTROM)", "TD BANK", "FIRST NATIONAL CREDIT CARD", "PENTAGON FEDERAL CREDIT UNION (PENFED)",
    "VERVENT", "AVANT", "FIFTH THIRD", "PETAL", "HUNTINGTON NATIONAL BANK", "KEYBANK", "REGIONS BANK", "M&T BANK",
    "BECU (BOEING EMPLOYEES CREDIT UNION)"
  )) %>%
  mutate(
    # 2024 vs 2025 - 60 - 6M
    bad_change_abs_60_6_202425 = bad60in6_2025 - bad60in6_2024,
    bad_change_rel_60_6_202425 = bad60in6_2025 / bad60in6_2024 - 1,

    # 90 - 6M
    bad_change_abs_90_6_202425 = bad90in6_2025 - bad90in6_2024,
    bad_change_rel_90_6_202425 = bad90in6_2025 / bad90in6_2024 - 1,

    # CO - 6M
    bad_change_abs_CO_6_202425 = COin6_2025 - COin6_2024,
    bad_change_rel_CO_6_202425 = COin6_2025 / COin6_2024 - 1
  )

write_csv(cards_sbs, "/shared/nas/shape/bu_fs/persist/Custom/Proactive-Card_Banking/DQCO/Refresh Requests/June 2026 Refresh/Data/Q32025_6MPerf.csv")
