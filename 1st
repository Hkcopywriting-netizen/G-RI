# Correlation check for the attributes used in the model
# Returns a correlation matrix and variance inflation factor calculation
def corrcheck(data, model_vars, target_name, wgts_name):
    res = {}
    weights = data[wgts_name].values

    for var in model_vars:
        X = data[[var]].values
        y = data[target_name].values
        lr = LogisticRegression(fit_intercept=False, max_iter=1000, solver='lbfgs')
        lr.fit(X, y, sample_weight=weights)
        res[var] = lr.decision_function(X)

    res_df = pd.DataFrame(res)

    vifs = []
    for var in model_vars:
        X_vif = res_df[[v for v in model_vars if v != var]].values
        y_vif = res_df[var].values
        lr_vif = LinearRegression()
        lr_vif.fit(X_vif, y_vif, sample_weight=weights)
        r2 = lr_vif.score(X_vif, y_vif)
        vif = 1 / (1 - r2) if r2 < 1 else float('inf')
        vifs.append({'var': var, 'vif': round(vif, 4)})

    cors = res_df.corr().round(3)
    vif_df = pd.DataFrame(vifs).sort_values('vif', ascending=False).reset_index(drop=True)

    return {'cors': cors, 'vifs': vif_df}


# Performance metric functions
def KS(data, target_name, score, weights):
    df = data[[target_name, score, weights]].copy().sort_values(score, ascending=False)
    w_good = df[weights] * (df[target_name] == 1)
    w_bad  = df[weights] * (df[target_name] == 0)
    cum_good = w_good.cumsum() / w_good.sum()
    cum_bad  = w_bad.cumsum()  / w_bad.sum()
    return (cum_good - cum_bad).abs().max()

def Gini(data, target_name, score, weights):
    auc = roc_auc_score(data[target_name], data[score], sample_weight=data[weights])
    return 2 * auc - 1

def ROC(data, target_name, score, weights):
    return roc_auc_score(data[target_name], data[score], sample_weight=data[weights])





