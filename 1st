# Reading the table with updated performance
cards_Q22024 <- tbl(sc, "bu_fs.hpusarl_Q2_2024_12m") %>% # ⚠️ CHANGED
  filter(year == "2024") # ⚠️ CHANGED

# Vantage 4.0
vtg4 <- tbl(sc, "common.scrattr_evtg04") %>%
  select(party_id, finscore, data_date) %>%
  rename(vtg4 = finscore)

################################################################################
########################## Performances & Metrics #############################
################################################################################

# Cards Q2 2024 - 12M # ⚠️ CHANGED
driver_Q22024_vtg <- cards_Q22024 %>% # ⚠️ CHANGED
  filter(!acct_typ_cde == "SC") %>%
  mutate(company = case_when(
    company == "LENDUP" ~ "MISSION LANE",
    subcode == "B22EL016" ~ "GENESIS FINANCIAL SOLUTIONS",
    TRUE ~ company
  ),
  archive_dte = case_when(
    month(open_dte) %in% c(1,2,3)    ~ paste0(as.character(year(open_dte)-1L), '-12-31'),
    month(open_dte) %in% c(4,5,6)    ~ paste0(as.character(year(open_dte)), '-03-31'),
    month(open_dte) %in% c(7,8,9)    ~ paste0(as.character(year(open_dte)), '-06-30'),
    month(open_dte) %in% c(10,11,12) ~ paste0(as.character(year(open_dte)), '-09-30')
  )) %>%
  left_join(vtg4, by = c("party_id", "archive_dte" = "data_date")) %>%
  mutate(vtg4Tier = case_when(
    vtg4 >= 300 & vtg4 <= 600 ~ '1. SUBPRIME',
    vtg4 > 600  & vtg4 <= 660 ~ '2. NEAR PRIME',
    vtg4 > 660  & vtg4 <= 720 ~ '3. PRIME',
    vtg4 > 720  & vtg4 <= 780 ~ '4. PRIME PLUS',
    vtg4 > 780                 ~ '5. SUPER PRIME',
    TRUE                       ~ '6. UNSCOREABLE'
  )) %>%
  mutate(
    BGI_60_12 = case_when( # ⚠️ CHANGED
      na30 <= 0 | na60 <= 0 ~ -1L,
      na60 <= 12            ~ 0L, # ⚠️ CHANGED
      na30 <= 12            ~ 2L, # ⚠️ CHANGED
      TRUE                  ~ 1L
    ),
    BGI_90_12 = case_when( # ⚠️ CHANGED
      na30 <= 0 | na60 <= 0 | na90 <= 0 ~ -1L,
      na90 <= 12                         ~ 0L, # ⚠️ CHANGED
      na60 <= 12                         ~ 2L, # ⚠️ CHANGED
      TRUE                               ~ 1L
    ),
    CO_12 = case_when(naCO <= 12 ~ 0L, TRUE ~ 1L) # ⚠️ CHANGED
  ) %>%
  compute("driver_Q22024_vtg") # ⚠️ CHANGED

cards_Q22024_Company <- driver_Q22024_vtg %>% # ⚠️ CHANGED
  group_by(company) %>%
  summarise(
    bad60in12 = sum(case_when(BGI_60_12 == 0 ~ 1L, TRUE ~ 0L), # ⚠️ CHANGED
                    na.rm = TRUE) /
      sum(case_when(BGI_60_12 %in% c(0, 1) ~ 1L, TRUE ~ 0L),
          na.rm = TRUE),
    bad90in12 = sum(case_when(BGI_90_12 == 0 ~ 1L, TRUE ~ 0L), # ⚠️ CHANGED
                    na.rm = TRUE) /
      sum(case_when(BGI_90_12 %in% c(0, 1) ~ 1L, TRUE ~ 0L),
          na.rm = TRUE),
    COin12 = sum(case_when(CO_12 == 0 ~ 1L, TRUE ~ 0L), na.rm = TRUE) / # ⚠️ CHANGED
      sum(case_when(CO_12 %in% c(0,1) ~ 1L, TRUE ~ 0L), na.rm = TRUE)
  ) %>%
  collect()

write_csv(cards_Q22024_Company, "/shared/nas/shape/bu_fs/persist/Custom/Proactive-Card_Banking/DQCO/Refresh Requests/June 2026 Refresh/Data/Q2_bad_COrates_2024_12m.csv") # ⚠️ CHANGED

