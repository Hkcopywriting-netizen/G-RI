total %>%
    mutate(control = if_else(Filtered_control == "Mailed", "Mailed", "Full Control")) %>%
    mutate(usbplOpen = if_else(lender == "USB", plOpen, 0)) %>%
    mutate(offUsbOpen = if_else(lender != "USB", plOpen, 0)) %>%
    group_by(control) %>%
    summarize(cnt = n(),
              responders = sum(usbInq),
              responseRate = responders/cnt,
              USBoriginations = sum(usbplOpen, na.rm = T),
              USBoriginationRate = USBoriginations/cnt,
              offUSBoriginations = sum(offUsbOpen, na.rm = T),
              offUSBOriginationRate = offUSBoriginations/cnt,
              USBShare = USBoriginations/(USBoriginations + offUSBoriginations)) %>%  # <-- ADD THIS LINE
    as.data.frame() %>% View()


